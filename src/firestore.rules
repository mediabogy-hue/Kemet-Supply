
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOrdersManager() {
      return exists(/databases/$(database)/documents/roles_orders_manager/$(request.auth.uid));
    }
    function isFinanceManager() {
      return exists(/databases/$(database)/documents/roles_finance_manager/$(request.auth.uid));
    }
    function isProductManager() {
      return exists(/databases/$(database)/documents/roles_product_manager/$(request.auth.uid));
    }

    function isStaff() {
      return isSignedIn() && (isAdmin() || isOrdersManager() || isFinanceManager() || isProductManager());
    }
    
    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId) || request.auth == null;
      allow update: if isOwner(userId) || isStaff();
      allow delete: if isAdmin();

      match /withdrawalRequests/{requestId} {
        allow read, write: if isOwner(userId) || isStaff();
      }
      match /payments/{paymentId} {
        allow read, write: if isOwner(userId) || isStaff();
      }
      match /bonuses/{bonusId} {
        allow read: if isOwner(userId) || isStaff();
        allow create, update, delete: if isStaff();
      }
      match /workSessions/{sessionId} {
        allow read, write: if isOwner(userId) || isStaff();
      }
    }
    
    // This single rule handles all 'list' and 'read' operations for the 'orders' collection group.
    match /{path=**}/orders/{orderId} {
      // READ (get a single doc) is allowed if user is staff or the owner of the parent user doc.
      // This is secure because get() checks the full path.
      allow get: if isStaff() || (isSignedIn() && get(parent(path)).id == request.auth.uid);
      
      // LIST (querying a collection) is allowed if user is staff OR if the query is
      // explicitly filtered by the user's own ID. This is secure because the rule
      // enforces the `where` clause on the client-side query.
      allow list: if isStaff() || (isSignedIn() && request.query.where.dropshipperId == request.auth.uid);
      
      // WRITE operations are handled separately for security.
      // Allow unauthenticated creation for public product pages IF they supply the correct dropshipperId.
      // Allow authenticated users to create orders for themselves.
      allow create: if (request.auth == null && request.resource.data.dropshipperId != null) || (isSignedIn() && request.resource.data.dropshipperId == request.auth.uid);
      // Only staff can update/delete.
      allow update: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow list: if isSignedIn();
      allow create, update, delete: if isStaff() || (isProductManager() && resource.data.merchantId == request.auth.uid);

       match /clicks/{clickId} {
        allow create: if true; 
        allow read, list, write: if isStaff();
      }
    }

    match /productCategories/{categoryId} {
      allow read, list: if true;
      allow write: if isStaff();
    }
    match /shipments/{shipmentId} {
        allow read, list, write: if isStaff();
        match /events/{eventId} {
            allow read, list, write: if isStaff();
        }
    }
    match /stockLedger/{ledgerId} {
      allow read, list, create, update, delete: if isStaff();
    }
    match /publicSettings/data {
        allow read: if true;
        allow write: if isAdmin();
    }
    match /systemSettings/{settingId} {
        allow read, write: if isAdmin();
    }
    match /auditLogs/{logId} {
        allow read, list, create, update, delete: if isAdmin();
    }
     match /merchantInquiries/{inquiryId} {
      allow create: if true;
      allow read, list, update, delete: if isStaff();
    }
    
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      allow read, update, list: if isParticipant();
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }
    match /conversations/{conversationId}/messages/{messageId} {
      function isParentConversationParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      allow read, list, create: if isParentConversationParticipant();
      allow update, delete: if false;
    }
    
    match /id_generator/{any} {
      allow read, write: if false;
    }
    
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /roles_product_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_orders_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_finance_manager/{userId} { allow read, write: if isAdmin(); }

    match /adminWithdrawalRequests/{requestId} {
      allow read, list, write: if isStaff();
      allow create: if isSignedIn();
    }
     match /adminPayments/{paymentId} {
      allow read, list, write: if isStaff();
       allow create: if isSignedIn();
    }

    match /marketingCustomers/{customerId} { 
        allow create, update: if true;
        allow read, delete: if isStaff();
    }
    match /marketingCampaigns/{any} { allow read, write: if isStaff(); }
    match /automationSettings/{any} { allow read, write: if isStaff(); }
  }
}
