
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Start of New, Corrected Role Functions ---
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isProductManager() {
        return exists(/databases/$(database)/documents/roles_product_manager/$(request.auth.uid));
    }
    function isOrdersManager() {
        return exists(/databases/$(database)/documents/roles_orders_manager/$(request.auth.uid));
    }
    function isFinanceManager() {
        return exists(/databases/$(database)/documents/roles_finance_manager/$(request.auth.uid));
    }
    function isStaff() {
       return isSignedIn() && (isAdmin() || isOrdersManager() || isFinanceManager() || isProductManager());
    }
    // --- End of New, Corrected Role Functions ---

    // --------------------------------
    // Collection Rules
    // --------------------------------

    // USERS: 
    // - A user can create their own user document (needed for sign-up).
    // - A user can read/update their own profile.
    // - Admin can read/list/write any profile.
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get, update: if isOwner(userId) || isAdmin(); // Admin can get/update any user
      allow list, delete: if isAdmin();
      
      // USER SUBCOLLECTIONS (Owned by the user)
      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }
      match /payments/{paymentId} {
         allow read, write: if isOwner(userId);
      }
      match /withdrawalRequests/{requestId} {
         allow read, write: if isOwner(userId);
      }
      match /bonuses/{bonusId} {
        allow read, write: if isOwner(userId) || isStaff(); // Staff can read/write bonuses
      }
      match /workSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // COLLECTION GROUP QUERIES:
    // Staff can perform collection group queries. This now works because isStaff() uses exists().
    match /{path=**}/orders/{orderId} { 
      allow list, get: if isStaff(); 
    }
    match /{path=**}/withdrawalRequests/{requestId} {
      allow list, get: if isStaff();
    }
     match /{path=**}/payments/{paymentId} {
      allow list, get: if isStaff();
    }
    match /{path=**}/workSessions/{sessionId} {
      allow list, get: if isStaff();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isProductManager() || isAdmin();

       match /clicks/{clickId} {
        allow create: if true; // Public click tracking
        allow read, list, write: if isAdmin() || isProductManager();
      }
    }
    
    // ROLE DOCUMENTS
    // Only Admins can manage roles.
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /roles_product_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_orders_manager/{userId} { allow read, write: if isAdmin(); }
    match /roles_finance_manager/{userId} { allow read, write: if isAdmin(); }

    // PUBLIC & ADMIN-ONLY COLLECTIONS
    match /productCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isProductManager();
    }
    match /shipments/{shipmentId} {
        allow read, write: if isStaff();
        match /events/{eventId} {
            allow read, write: if isStaff();
        }
    }
    match /stockLedger/{ledgerId} {
      allow read, write: if isStaff();
    }
    match /paymentMethods/{methodId} {
        allow read: if isSignedIn();
        allow write: if isStaff();
    }
    match /publicSettings/data {
        allow read: if true;
        allow write: if isAdmin();
    }
    match /systemSettings/{settingId} {
        allow read, write: if isAdmin();
    }
    match /auditLogs/{logId} {
        allow read, write: if isAdmin();
    }
     match /merchantInquiries/{inquiryId} {
      allow create: if true;
      allow read, list, update, delete: if isStaff();
    }
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      allow read, update: if isParticipant();
      allow create: if request.auth.uid in request.resource.data.participantIds;
    }
    match /conversations/{conversationId}/messages/{messageId} {
      function isParentConversationParticipant() {
        return request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      allow read, create: if isParentConversationParticipant();
      allow update, delete: if false;
    }
  }
}
