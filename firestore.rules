
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isOrdersManager() {
        return exists(/databases/$(database)/documents/roles_orders_manager/$(request.auth.uid)) || isAdmin();
    }

    function isFinanceManager() {
        return exists(/databases/$(database)/documents/roles_finance_manager/$(request.auth.uid)) || isAdmin();
    }
    
    function isMerchant() {
        return exists(/databases/$(database)/documents/roles_merchant/$(request.auth.uid));
    }

    function isStaff() {
        return isAdmin() || isOrdersManager() || isFinanceManager();
    }

    // Default-deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId) || isStaff();
      allow update: if isOwner(userId) || isAdmin();
      allow list, delete: if isAdmin();
    }
    
    // Wallets
    match /wallets/{userId} {
        allow get: if isOwner(userId) || isFinanceManager();
        allow create, update: if false; // Managed by server-side logic
    }

    // Role documents for permission checks.
    // This is a hardened rule to prevent any recursion.
    // `exists()` calls in functions do not require `get` permission.
    match /roles_admin/{userId} { 
        allow get: if isOwner(userId);
        allow write, list, delete: if isAdmin();
     }
    match /roles_orders_manager/{userId} {
        allow get: if isOwner(userId);
        allow write, list, delete: if isAdmin();
    }
    match /roles_finance_manager/{userId} {
        allow get: if isOwner(userId);
        allow write, list, delete: if isAdmin();
    }
    match /roles_merchant/{userId} {
        allow get: if isOwner(userId);
        allow write, list, delete: if isAdmin();
    }
    
    // Public Settings
    match /publicSettings/{docId} {
        allow get: if true;
        allow write: if isAdmin();
    }

    // Products and Categories
    match /products/{productId} {
        allow read, list: if isSignedIn();
        allow create: if (isMerchant() && request.resource.data.merchantId == request.auth.uid) || isAdmin();
        allow update, delete: if (isMerchant() && resource.data.merchantId == request.auth.uid) || isAdmin();
    }
    match /productCategories/{categoryId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
    }
     // Anyone can track a product click via the public page
    match /products/{productId}/clicks/{clickId} {
        allow create: if true;
        allow read, list, update, delete: if false;
    }
    
    // Orders
    match /orders/{orderId} {
      allow create: if (request.auth != null && request.resource.data.dropshipperId == request.auth.uid) || request.auth == null;
      allow get: if isStaff() || isOwner(resource.data.dropshipperId) || (isMerchant() && resource.data.merchantId == request.auth.uid);
      allow list: if isStaff();
      allow update: if isOrdersManager() || 
                    (isMerchant() && 
                     resource.data.merchantId == request.auth.uid &&
                     resource.data.status == 'Pending' &&
                     request.resource.data.status == 'Confirmed' &&
                     request.resource.data.keys().hasAll(['status', 'updatedAt', 'confirmedAt']));
      allow delete: if isAdmin();
    }

    // Withdrawal requests
    match /adminWithdrawalRequests/{reqId} {
        allow read, list, update, delete: if isFinanceManager();
        allow create: if false; // Only server can create
    }
    match /users/{userId}/withdrawalRequests/{reqId} {
        allow read, list: if isOwner(userId);
        allow create, update, delete: if false; // Managed by server-side logic
    }
    
    // Merchant Inquiries can be created by anyone.
    match /merchantInquiries/{inquiryId} {
        allow create: if true;
        allow read, list, update, delete: if isAdmin();
    }
    
     // Marketing customers can be created by anyone who successfully refers them
    match /marketingCustomers/{contactId} {
      allow create, update: if true;
      allow read, list, delete: if isAdmin();
    }

    // Stock Ledger
    match /stockLedger/{ledgerId} {
        function isProductOwner(productId) {
            let product = get(/databases/$(database)/documents/products/$(productId)).data;
            return product.keys().has('merchantId') && product.merchantId == request.auth.uid;
        }
        allow read, list: if isAdmin();
        allow create: if isAdmin() || (isMerchant() && isProductOwner(request.resource.data.productId));
        allow update, delete: if false;
    }

    // Helper collections
    match /id_generator/{docId} {
        allow create: if isSignedIn();
    }
    match /webhooks_bosta/{webhookId} {
        allow create: if true; // Webhooks can write
        allow read, list, update, delete: if isAdmin();
    }
  }
}
