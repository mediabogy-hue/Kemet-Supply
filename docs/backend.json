{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the system, which can be a Dropshipper or an Admin-level role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user, used for login.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, defining their permissions.",
          "enum": [
            "Dropshipper",
            "Admin",
            "OrdersManager",
            "FinanceManager",
            "Merchant"
          ]
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean"
        },
        "initialPasswordChangeRequired": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt",
        "updatedAt",
        "isActive"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed on the platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "merchantId": { "type": "string", "description": "The ID of the Merchant who owns this product." }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "dropshipperId": { "type": "string" },
        "merchantId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product details."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores order details."
    }
  }
}
