
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the system, which can be a Dropshipper or an Admin-level role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user, used for login.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, defining their permissions.",
          "enum": ["Dropshipper", "Admin", "OrdersManager", "FinanceManager", "ProductManager"]
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean"
        },
         "initialPasswordChangeRequired": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt",
        "updatedAt",
        "isActive"
      ]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/entities/User"
          }
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": { "description": "Grants Admin role." }
      },
      {
        "path": "/roles_orders_manager/{userId}",
        "definition": { "description": "Grants Orders Manager role." }
      },
      {
        "path": "/roles_finance_manager/{userId}",
        "definition": { "description": "Grants Finance Manager role." }
      },
      {
        "path": "/roles_product_manager/{userId}",
        "definition": { "description": "Grants Product Manager role." }
      }
    ]
  }
}
